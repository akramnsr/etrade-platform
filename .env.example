# Database
DB_URL=jdbc:postgresql://localhost:5432/etrade_db
DB_USERNAME=etrade_user
DB_PASSWORD=etrade_password
DB_NAME=etrade_db

# Keycloak
KEYCLOAK_ISSUER_URI=http://localhost:8180/realms/etrade
KEYCLOAK_JWK_SET_URI=http://localhost:8180/realms/etrade/protocol/openid-connect/certs

# Application
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Frontend
VITE_API_BASE_URL=http://localhost:8080
VITE_KEYCLOAK_URL=http://localhost:8180
VITE_KEYCLOAK_REALM=etrade
VITE_KEYCLOAK_CLIENT_ID=etrade-frontend

# Production only
REGISTRY=ghcr.io/akramnsr
VERSION=latest
FRONTEND_URL=https://etrade.portnet.ma
